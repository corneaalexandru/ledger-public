# Ledger Public uses a user-owned Google Sheet.
LEDGER_STORE=google

# The spreadsheet ID from the Google Sheet URL.
# Example URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID_HERE/edit
LEDGER_SPREADSHEET_ID=your_google_sheet_id_here

# Path to your own service-account JSON file.
# This file is ignored by Git and must never be committed.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/ledger-service-account.json
