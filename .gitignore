.DS_Store
.env
.env.*
!.env.example
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log
*.json

# User-owned Google auth files. Never commit service-account credentials.
credentials/*
!credentials/.gitkeep
.ledger_public_setup/

# Starter database template is tracked. User-created workbooks remain ignored.
!starter/ledger_starter_workbook.xlsx

# Legacy/local runtime data. Ignored so older installs and test runs do not
# commit personal ledger rows.
local_ledger_data/
local_ledger_workbook.xlsx
local_ledger_backups/
google_ledger_backups/

# Legacy local data names from early public builds. Ignored and migrated on run.
mock_google_sheet/
mock_ledger_google_sheet.xlsx
